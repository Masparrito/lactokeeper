rules_version = '2';

// Reglas de seguridad de Firestore para LactoKeeper / GanaderoOS.
//
// Modelo: una cuenta = un ganadero. CADA documento de datos lleva un campo
// `userId` con el uid de su dueño, y solo ese dueño puede leer, crear, editar
// y BORRAR sus documentos.
//
// La regla de datos es un COMODÍN sobre `/{collection}/{docId}`: cubre de forma
// automática todas las colecciones (animals, weighings, parturitions,
// famachaRevs, …) y también las que se agreguen en el futuro, sin tener que
// volver a tocar estas reglas. Esto evita justamente el bug que originó este
// archivo: una colección nueva (`famachaRevs`) que permitía crear/editar pero
// NO borrar, dejando los borrados atascados con `permission-denied`.

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Configuración de la app ---
    // Un documento por usuario, con id = uid. No lleva campo `userId`: la
    // propiedad se deriva del propio id del documento.
    match /configuracion/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // --- Datos del ganado (comodín para todas las colecciones) ---
    // El dueño (y solo el dueño) tiene control total sobre sus documentos.
    match /{collection}/{docId} {
      // Leer / consultar: el documento debe pertenecer al usuario autenticado.
      // (Las consultas de la app filtran por `userId == uid`, así que cumplen.)
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      // Crear: el documento entrante debe declararse propiedad del usuario.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Editar: debe ser dueño del documento existente y seguir siéndolo tras
      // el cambio (no se puede transferir a otro usuario).
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;

      // Borrar: solo el dueño del documento existente.
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
